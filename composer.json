{
    "name": "vending-machine/project",
    "description": "A PHP project for a vending machine system with API and web components.",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Api\\": "api/",
            "Web\\": "web/",
            "Api\\Controllers\\": "api/controllers/",
            "Web\\Controllers\\": "web/controllers/",
            "Web\\Tests\\": "web/tests/",
            "Api\\Tests\\": "api/tests/",
            "Web\\Traits\\": "web/traits/",
            "App\\": "app/"

        }
    },
    "require": {
        "firebase/php-jwt": "^7.0",
        "php": "^8.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.4"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:feature": "phpunit --testsuite feature",
        "test:e2e": "python3 tests/e2e/storefront_endpoint_test.py",
        "post-install-cmd": [
            "@php -r \"file_exists('vendor/autoload.php') || copy('vendor/autoload.php', 'public/vendor/autoload.php');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "platform": {
            "php": "8.5.6"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
